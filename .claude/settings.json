{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "npx tsc --noEmit --pretty 2>&1 | head -20",
        "description": "TypeScript check after edits"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "case \"$CLAUDE_FILE_PATH\" in *.env|*.env.*) echo 'BLOCKED: .env contains secrets — do not edit' && exit 1;; esac",
        "description": "Protect .env files from edits"
      }
    ]
  }
}
